// kthmax 

#include<vector>
#include<iostream>
#include<algorithm>

using namespace std;

void kthMax(vector<int> &vec) {
    sort(vec.begin(), vec.end());
}

int main() {

    int k;
    cin >> k;

    vector<int> vec = {5,7,2,3,1,9,8};

    kthMax(vec);

    cout << vec[vec.size() - k];

    return 0;
}
