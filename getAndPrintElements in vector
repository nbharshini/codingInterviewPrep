// vector how to get elements in a vector

#include<vector>
#include<iostream>
using namespace std;

void printVector(){
    int n;
    cin>> n; // size of the vector
    vector<int>nums(n); 
    for(int i=0;i<n;i++){
        cin>>nums[i];
    }
    for(int i=0;i<n;i++){
        cout<<nums[i]<<" ";
    }
}


int main(){
    printVector();

    return 0;
    
    
}
