// reverse array elements without extra space

class Solution {
  public:
    void swap(int &a, int &b){
        int t = a;
        a = b;
        b = t;
    }
    void reverseArray(vector<int> &arr) {
        // code here
        int i = 0; // first element
        int j = arr.size()-1; // last element
        
        while(i<j){ // i less than j 
            swap(arr[i],arr[j]); // swap first with last, then rest i by incrementing and decrementing j --> swap again, this will happen till i < j
            i++;
            j--;
        }
        
        
    }
};
