// Move all negative numbers to beginning and positive to end with constant extra space
#include<vector>
#include<iostream>

using namespace std;

void moveNegative(vector<int>& vec) {

    int left = 0;
    int right = vec.size() - 1;

    while(left < right) {

        if(vec[left] < 0) {
            left++;
        }

        else if(vec[right] > 0) {
            right--;
        }

        else {
            swap(vec[left], vec[right]);
            left++;
            right--;
        }
    }
}

int main() {

    vector<int> vec = {
        -1,-2,-3,5,7,2,3,1,9,8,-4,-5,-6,-7,-9
    };

    moveNegative(vec);

    for(int i = 0; i < vec.size(); i++) {
        cout << vec[i] << " ";
    }

    return 0;
}
