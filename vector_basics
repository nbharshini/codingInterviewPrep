## Full Example

```cpp
#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int main() {

    vector<int> nums;

    nums.push_back(30);
    nums.push_back(10);
    nums.push_back(20);

    cout << "Elements: ";

    for(int i = 0; i < nums.size(); i++) {
        cout << nums[i] << " ";
    }

    cout << endl;

    sort(nums.begin(), nums.end());

    cout << "Sorted: ";

    for(int num : nums) {
        cout << num << " ";
    }

    return 0;
}
```

Output:

```cpp
Elements: 30 10 20
Sorted: 10 20 30
```

