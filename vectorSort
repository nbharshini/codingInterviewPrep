// kthmax kth min
#include<vector>
#include<iostream>
#include<algorithm>

using namespace std;

void kthmax(vector<int> & vec){
    sort(vec.begin(),vec.end());
}


int main(){
    int n;
    cin>> n;
    vector <int> vec = {5,7,2,3,1,9,8};
    // {1,2,3,5,7,8,9}
    kthmax(vec);
    cout<<vec[n-1];

    return 0;
    
    
}
