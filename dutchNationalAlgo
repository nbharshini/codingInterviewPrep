Initialize low = 0, mid = 0, and high = length_of_array - 1.Loop while mid <= high:Case 0 (arr[mid] == 0): Swap arr[low] and arr[mid]. Increment both low and mid by 1.Case 1 (arr[mid] == 1): Do nothing except incrementing mid by 1.Case 2 (arr[mid] == 2): Swap arr[mid] and arr[high]. Decrement high by 1. 
  Do not increment mid here, as the swapped element from high is uninspected.


#include <iostream>
#include <vector>
#include <utility> // For std::swap

// Function implementing the Dutch National Flag Algorithm
void dutchNationalFlagSort(std::vector<int>& arr) {
    int low = 0;
    int mid = 0;
    int high = arr.size() - 1;

    // Traverse the array until mid crosses high
    while (mid <= high) {
        if (arr[mid] == 0) {
            std::swap(arr[low], arr[mid]);
            low++;
            mid++;
        } 
        else if (arr[mid] == 1) {
            mid++;
        } 
        else { // arr[mid] == 2
            std::swap(arr[mid], arr[high]);
            high--;
        }
    }
}

int main() {
    std::vector<int> arr = {2, 0, 2, 1, 1, 0, 1, 2, 0};

    std::cout << "Original Array: ";
    for (int num : arr) std::cout << num << " ";
    std::cout << "\n";

    dutchNationalFlagSort(arr);

    std::cout << "Sorted Array:   ";
    for (int num : arr) std::cout << num << " ";
    std::cout << "\n";

    return 0;
}
