/*
### Algorithm

We use **2 stacks**:

1. `st` → stores all elements normally.
2. `minSt` → stores the minimum element till that point.

### Steps

#### `push(val)`

1. Push value into normal stack `st`.
2. Check:

   * if `minSt` is empty → push value.
   * if `val <= minSt.top()` → push into `minSt`.

Why?

Because if current value is **smaller or equal to current minimum**, it can become the new minimum.

---

#### `pop()`

1. Check if top of `st` equals top of `minSt`.
2. If yes → pop from `minSt`.
3. Pop from `st`.

Why?

Because if removed element is the **current minimum**, we must remove it from `minSt` too.

---

#### `top()`

Return top element of `st`.

---

#### `getMin()`

Return top of `minSt`.

Why?

Because `minSt` always keeps track of current minimum.

---

*/

class MinStack {
public:

    // Normal stack to store all elements
    stack<int> st;

    // Stack to store minimum elements
    stack<int> minSt;

    // Constructor
    MinStack() {

    }

    void push(int val) {

        // Push value into normal stack
        st.push(val);

        // If min stack is empty,
        // first element becomes minimum
        // OR if current value is smaller/equal
        // than current minimum, push it
        if(minSt.empty() || val <= minSt.top()) {
            minSt.push(val);
        }
    }

    void pop() {

        // If top element is current minimum,
        // remove it from min stack also
        // to maintain correct minimum
        if(st.top() == minSt.top()) {
            minSt.pop();
        }

        // Remove from main stack
        st.pop();
    }

    int top() {

        // Return top element
        return st.top();
    }

    int getMin() {

        // Top of min stack
        // always stores minimum
        return minSt.top();
    }
};

